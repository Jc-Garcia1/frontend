import { useState } from "react";
import {
    useCreateDepartament,
    useDepartaments,
    useDeleteDepartament,
    useUpdateDepartament
} from "../api/departaments.queries";

export default function DepartamentsPage() {
    const { data = [], isLoading, isError, error, refetch } = useDepartaments();

    const createMut = useCreateDepartament();
    const updateMut = useUpdateDepartament();
    const deleteMut = useDeleteDepartament();

    const [name, setname] = useState("");
    const [editingId, setEditingId] = useState<number | null>(null);

    async function onSubmit(e: React.FormEvent) {
        e.preventDefault();

        if (editingId) {
            await updateMut.mutateAsync({
                id: editingId,
                dto: { name }
            });

            setEditingId(null);
        } else {
            await createMut.mutateAsync({ name });
        }

        setname("");
    }

    function onEdit(dep: any) {
        setEditingId(dep.id);
        setname(dep.name);
    }

    return (
        <div className="bg-slate-50 min-h-screen">
            <header className="border-b bg-black">
                <div className="mx-auto max-w-5xl px-4 py-4 flex items-center justify-between">
                    <h1 className="text-xl font-semibold text-white">
                        Departaments
                    </h1>

                    <button
                        className="rounded-lg border px-3 py-2 text-white"
                        onClick={() => refetch()}
                    >
                        Reintentar/Refrescar
                    </button>
                </div>
            </header>

            <main className="mx-auto max-w-5xl px-4 py-6 space-y-4">

                {/* FORM */}
                <form
                    onSubmit={onSubmit}
                    className="rounded-xl border bg-white p-4 space-y-3"
                >
                    <div className="grid gap-3 md:grid-cols-2">
                        <div>
                            <label className="block text-sm font-medium mb-1">
                                Nombre
                            </label>

                            <input
                                className="w-full rounded-lg border px-3 py-2"
                                value={name}
                                onChange={(e) => setname(e.target.value)}
                                required
                            />
                        </div>
                    </div>

                    <div className="flex gap-2">
                        <button
                            className="rounded-lg bg-black px-4 py-2 text-white disabled:opacity-50"
                            disabled={createMut.isPending || updateMut.isPending}
                        >
                            {editingId
                                ? updateMut.isPending
                                    ? "Actualizando..."
                                    : "Actualizar"
                                : createMut.isPending
                                    ? "Creando..."
                                    : "Crear"}
                        </button>

                        {editingId && (
                            <button
                                type="button"
                                className="rounded-lg border px-4 py-2"
                                onClick={() => {
                                    setEditingId(null);
                                    setname("");
                                }}
                            >
                                Cancelar
                            </button>
                        )}
                    </div>

                    {createMut.isError && (
                        <p className="text-sm text-red-600">
                            Error creando: {String(createMut.error)}
                        </p>
                    )}

                    {updateMut.isError && (
                        <p className="text-sm text-red-600">
                            Error actualizando: {String(updateMut.error)}
                        </p>
                    )}
                </form>

                {/* TABLE */}
                <div className="rounded-xl border bg-white">
                    <div className="p-4 border-b">
                        {isLoading && (
                            <p className="text-sm text-slate-600">
                                Cargando…
                            </p>
                        )}

                        {isError && (
                            <p className="text-sm text-red-600">
                                Error: {String(error)}
                            </p>
                        )}

                        {!isLoading && !isError && (
                            <p className="text-sm text-slate-600">
                                {data.length} registro(s)
                            </p>
                        )}
                    </div>

                    <div className="overflow-x-auto">
                        <table className="w-full text-sm">
                            <thead className="bg-slate-50 text-left">
                                <tr>
                                    <th className="p-3">Nombre</th>
                                    <th className="p-3 w-52">Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                {data.map((c) => (
                                    <tr key={c.id} className="border-t">
                                        <td className="p-3">{c.name}</td>

                                        <td className="p-3">
                                            <div className="flex gap-2">

                                                <button
                                                    className="rounded-md bg-blue-600 px-3 py-1 text-white hover:bg-blue-700"
                                                    onClick={() => onEdit(c)}
                                                >
                                                    Editar
                                                </button>

                                                <button
                                                    className="rounded-md border px-3 py-1 hover:bg-slate-50 disabled:opacity-50"
                                                    disabled={deleteMut.isPending}
                                                    onClick={() => {
                                                        if (
                                                            !confirm(
                                                                "¿Seguro que deseas borrar este departamento?"
                                                            )
                                                        ) return;

                                                        deleteMut.mutate(c.id);
                                                    }}
                                                >
                                                    Borrar
                                                </button>

                                            </div>
                                        </td>
                                    </tr>
                                ))}

                                {!isLoading &&
                                    !isError &&
                                    data.length === 0 && (
                                        <tr>
                                            <td
                                                className="p-6 text-center text-slate-500"
                                                colSpan={2}
                                            >
                                                No hay registros.
                                            </td>
                                        </tr>
                                    )}
                            </tbody>
                        </table>
                    </div>

                    {deleteMut.isError && (
                        <div className="p-4">
                            <p className="text-sm text-red-600">
                                Error borrando: {String(deleteMut.error)}
                            </p>
                        </div>
                    )}
                </div>
            </main>
        </div>
    );
}